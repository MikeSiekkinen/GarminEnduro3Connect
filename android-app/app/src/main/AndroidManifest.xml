<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Legacy Bluetooth (Android < 12) -->
    <uses-permission android:name="android.permission.BLUETOOTH" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" />

    <!-- Bluetooth on Android 12+ -->
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />

    <!-- Location required for BLE scanning on Android < 12 and for geocoding -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Required on Android 13+ for Everysight SDK notification channel -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Everysight SDK validates API key with Everysight server -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Everysight SDK's PreviewService runs as a foreground service for BLE. SDK's manifest
         omits these (untested on Android 14+); without them startForeground silently throws
         MissingForegroundServiceTypeException and the SDK never scans. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />

    <uses-feature android:name="android.hardware.bluetooth_le" android:required="true" />

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:theme="@style/Theme.GarminEnduro3"
        android:supportsRtl="true"
        tools:replace="android:theme">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Add the foregroundServiceType the SDK's manifest forgot. -->
        <service
            android:name="com.everysight.evskit.android.internal.ui.preview.PreviewService"
            android:foregroundServiceType="connectedDevice"
            tools:node="merge" />

    </application>

</manifest>
